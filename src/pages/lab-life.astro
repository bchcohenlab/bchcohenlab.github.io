---
import { getCollection } from "astro:content";
import BaseLayout from "../components/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import GalleryGrid from "../components/GalleryGrid.astro";

const items = (await getCollection("gallery")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout
  title="Lab Life"
  description="Photos from life in the Cohen Lab."
>
  <PageHeader
    eyebrow="Beyond the bench"
    title="Lab Life"
    lead="Conferences, celebrations, and everyday life in the lab."
  />
  <div class="container-page py-12">
    {
      items.length > 0 ? (
        <GalleryGrid items={items} />
      ) : (
        <p class="py-10 text-center text-slate-500">
          Photos coming soon — check back as we add them.
        </p>
      )
    }
  </div>
</BaseLayout>
