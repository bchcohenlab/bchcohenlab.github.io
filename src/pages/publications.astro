---
import BaseLayout from "../components/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import PubList from "../components/PubList.astro";
import { getPublications } from "../lib/content";

const pubs = await getPublications();

const chip =
  "rounded-full border border-slate-300 px-3 py-1 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50 data-[active]:border-primary-600 data-[active]:bg-primary-600 data-[active]:text-white";

const filters = [
  { key: "all", label: "All" },
  { key: "mentee", label: "Mentee-led" },
  { key: "cohen", label: "Cohen first/senior" },
  { key: "collaboration", label: "Collaboration" },
  { key: "openaccess", label: "Open access" },
];
---

<BaseLayout
  title="Publications"
  description="Peer-reviewed publications from the Cohen Lab. Filter by mentee-led, Cohen first/senior, collaboration, or open access; sort by date or citations."
>
  <PageHeader
    eyebrow="Research output"
    title="Publications"
    lead="Peer-reviewed work from the lab and its collaborators. Filter by the role badges, sort by date or citation count; counts are from Google Scholar."
  />
  <div class="container-page py-12">
    <div class="mb-8 space-y-3">
      <div class="flex flex-wrap items-center gap-2">
        {
          filters.map((f) => (
            <button class={chip} data-filter={f.key} data-active={f.key === "all" ? "" : undefined}>
              {f.label} <span data-count />
            </button>
          ))
        }
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <input
          type="search"
          id="pub-search"
          placeholder="Search title or author…"
          class="min-w-56 flex-1 rounded-md border border-slate-300 px-3 py-1.5 text-sm focus:border-primary-500 focus:outline-none"
        />
        <div class="flex items-center gap-2 text-sm text-slate-500">
          <span>Sort</span>
          <button class={chip} data-sort="date" data-active>Newest</button>
          <button class={chip} data-sort="citations">Most cited</button>
        </div>
        <span id="pub-count" class="text-sm text-slate-500"></span>
      </div>
    </div>

    <PubList pubs={pubs} />

    <p id="pub-empty" class="hidden py-10 text-center text-slate-500">
      No publications match your filters.
    </p>
  </div>

  <script>
    const list = document.getElementById("pub-list");
    const items = list
      ? ([...list.querySelectorAll<HTMLElement>("[data-pub]")] as HTMLElement[])
      : [];
    const search = document.getElementById("pub-search") as HTMLInputElement | null;
    const countEl = document.getElementById("pub-count");
    const emptyEl = document.getElementById("pub-empty");
    const filterBtns = [...document.querySelectorAll<HTMLElement>("[data-filter]")];
    const sortBtns = [...document.querySelectorAll<HTMLElement>("[data-sort]")];

    // filter key -> the li dataset flag it tests ("all" tests nothing)
    const FLAG: Record<string, string> = {
      mentee: "mentee",
      cohen: "cohenSenior",
      collaboration: "collaboration",
      openaccess: "openaccess",
    };
    let filter = "all";
    let sort = "date";

    const num = (li: HTMLElement, k: string) => Number(li.dataset[k] ?? 0);

    function fillCounts() {
      for (const b of filterBtns) {
        const f = b.dataset.filter!;
        const c =
          f === "all" ? items.length : items.filter((li) => li.dataset[FLAG[f]] === "true").length;
        const span = b.querySelector("[data-count]");
        if (span) span.textContent = `(${c})`;
      }
    }

    function applySort() {
      if (!list) return;
      const arr = [...items].sort((a, b) =>
        sort === "citations"
          ? num(b, "citations") - num(a, "citations") || num(b, "year") - num(a, "year")
          : num(b, "year") - num(a, "year"),
      );
      for (const li of arr) list.appendChild(li);
    }

    function applyFilter() {
      const q = (search?.value ?? "").trim().toLowerCase();
      let n = 0;
      for (const li of items) {
        const okFilter = filter === "all" || li.dataset[FLAG[filter]] === "true";
        const okSearch = !q || (li.dataset.search ?? "").includes(q);
        const show = okFilter && okSearch;
        li.hidden = !show;
        if (show) n++;
      }
      if (countEl) countEl.textContent = `${n} of ${items.length}`;
      if (emptyEl) emptyEl.classList.toggle("hidden", n !== 0);
    }

    const setActive = (btns: HTMLElement[], active: HTMLElement) => {
      for (const x of btns) {
        if (x === active) x.setAttribute("data-active", "");
        else x.removeAttribute("data-active");
      }
    };

    for (const b of filterBtns)
      b.addEventListener("click", () => {
        filter = b.dataset.filter ?? "all";
        setActive(filterBtns, b);
        applyFilter();
      });
    for (const b of sortBtns)
      b.addEventListener("click", () => {
        sort = b.dataset.sort ?? "date";
        setActive(sortBtns, b);
        applySort();
      });
    search?.addEventListener("input", applyFilter);

    fillCounts();
    applySort();
    applyFilter();
  </script>
</BaseLayout>
