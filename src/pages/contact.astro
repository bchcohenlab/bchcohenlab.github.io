---
import BaseLayout from "../components/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { site } from "../data/site";

const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(site.mapQuery)}&output=embed`;
const mapLink = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(site.mapQuery)}`;
const socials = [
  { label: "Google Scholar", href: site.social.scholar },
  { label: "X / Twitter", href: site.social.twitter },
  { label: "GitHub", href: site.social.github },
].filter((s): s is { label: string; href: string } => Boolean(s.href));
---

<BaseLayout
  title="Contact"
  description="Contact the Cohen Laboratory of Translational Neuroimaging at Boston Children's Hospital."
>
  <PageHeader
    eyebrow="Get in touch"
    title="Contact"
    lead="We welcome inquiries from prospective trainees, collaborators, and research participants' families."
  />
  <div class="container-page py-12">
    <div class="grid gap-8 lg:grid-cols-2 lg:items-stretch">
      <div class="rounded-xl border border-slate-200 bg-white p-6">
        <h2 class="font-serif text-xl text-slate-900">Cohen Lab</h2>
        <address class="mt-3 text-slate-600 not-italic">
          {site.address.map((line) => <p>{line}</p>)}
        </address>

        <dl class="mt-6 space-y-2 text-sm">
          <div class="flex gap-2">
            <dt class="font-medium text-slate-600">Email</dt>
            <dd>
              <a
                href={`mailto:${site.email}`}
                class="text-primary-700 hover:underline">{site.email}</a
              >
            </dd>
          </div>
          <div class="flex gap-2">
            <dt class="font-medium text-slate-600">Phone</dt>
            <dd>
              <a
                href={`tel:${site.phone.replace(/[^0-9+]/g, "")}`}
                class="text-primary-700 hover:underline">{site.phone}</a
              >
            </dd>
          </div>
        </dl>

        <h3 class="mt-8 text-sm font-semibold tracking-wide text-slate-600 uppercase">
          Elsewhere
        </h3>
        <ul class="mt-2 space-y-1 text-sm">
          {
            socials.map((s) => (
              <li>
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary-700 hover:underline"
                >
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="flex flex-col gap-3">
        <div class="grow overflow-hidden rounded-xl border border-slate-200 shadow-sm">
          <iframe
            title="Map to Two Brookline Place"
            src={mapSrc}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="h-80 w-full lg:h-full"></iframe>
        </div>
        <a
          href={mapLink}
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-center gap-1 self-start text-sm font-medium text-primary-700 transition-colors hover:text-accent-600"
        >
          Open in Google Maps
          <span class="transition-transform group-hover:translate-x-0.5" aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
