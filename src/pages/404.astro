---
import BaseLayout from "../components/BaseLayout.astro";
---

<BaseLayout title="Page not found">
  <div class="container-page flex flex-col items-center py-28 text-center">
    <p class="font-serif text-6xl font-semibold text-primary-700">404</p>
    <h1 class="mt-4 font-serif text-2xl text-slate-900">Page not found</h1>
    <p class="mt-3 max-w-md text-slate-600">
      The page you're looking for doesn't exist or may have moved in our recent
      site rebuild.
    </p>
    <a
      href="/"
      class="mt-8 rounded-md bg-primary-700 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-primary-800"
      >Back to home</a
    >
  </div>
</BaseLayout>
