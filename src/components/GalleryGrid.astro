---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  items: CollectionEntry<"gallery">[];
}
const { items } = Astro.props;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long" });
---

<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
  {
    items.map((item) => (
      <figure class="overflow-hidden rounded-xl border border-slate-200 bg-white">
        <Image
          src={item.data.image}
          alt={item.data.caption}
          widths={[400, 800]}
          sizes="(min-width: 640px) 50vw, 100vw"
          class="aspect-[4/3] w-full object-cover"
        />
        <figcaption class="p-4">
          <p class="text-sm text-slate-700">{item.data.caption}</p>
          <p class="mt-1 text-xs text-slate-500">{fmtDate(item.data.date)}</p>
        </figcaption>
      </figure>
    ))
  }
</div>
