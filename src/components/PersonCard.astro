---
import { Image } from "astro:assets";
import type { Person } from "../lib/content";

interface Props {
  person: Person;
}
const { person } = Astro.props;
const { name, role, headshot, links } = person.data;

const initials = name
  .split(",")[0]
  .split(/\s+/)
  .map((t) => t[0])
  .filter(Boolean)
  .slice(0, 2)
  .join("")
  .toUpperCase();

// Small social badges under each card — only LinkedIn + ORCID, only when present.
const badges = [
  links.linkedin && {
    label: "LinkedIn",
    href: links.linkedin,
    color: "#0A66C2",
    d: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
  },
  links.orcid && {
    label: "ORCID",
    href: links.orcid,
    color: "#A6CE39",
    d: "M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947 0 .525-.422.947-.947.947-.525 0-.946-.422-.946-.947 0-.516.421-.947.946-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z",
  },
].filter(Boolean) as { label: string; href: string; color: string; d: string }[];
---

<div class="text-center">
  <a href={`/people/${person.id}`} class="group block">
    <div
      class="mx-auto h-32 w-32 overflow-hidden rounded-full ring-1 ring-slate-200 transition duration-300 group-hover:shadow-md group-hover:ring-2 group-hover:ring-primary-300"
    >
      {
        headshot ? (
          <Image
            src={headshot}
            alt={name}
            width={256}
            height={256}
            class="h-full w-full object-cover"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center bg-primary-100 text-2xl font-semibold text-primary-700">
            {initials}
          </div>
        )
      }
    </div>
    <h3
      class="mt-3 font-serif text-base text-slate-900 group-hover:text-primary-700"
    >
      {name}
    </h3>
    <p class="text-sm text-slate-600">{role}</p>
  </a>
  {
    badges.length > 0 && (
      <div class="mt-1.5 flex justify-center gap-2.5">
        {badges.map((b) => (
          <a
            href={b.href}
            target="_blank"
            rel="noopener noreferrer"
            title={b.label}
            aria-label={`${name} on ${b.label}`}
            class="text-slate-300 transition-colors hover:[color:var(--c)]"
            style={`--c:${b.color}`}
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor" aria-hidden="true">
              <path d={b.d} />
            </svg>
          </a>
        ))}
      </div>
    )
  }
</div>
