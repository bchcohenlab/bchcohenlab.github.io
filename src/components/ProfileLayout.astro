---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import type { Person } from "../lib/content";

interface Props {
  person: Person;
}
const { person } = Astro.props;
const { name, role, title, headshot, links } = person.data;

const initials = name
  .split(",")[0]
  .split(/\s+/)
  .map((t) => t[0])
  .filter(Boolean)
  .slice(0, 2)
  .join("")
  .toUpperCase();

type LinkType = "email" | "website" | "scholar" | "orcid" | "twitter" | "linkedin";
const linkItems = [
  links.email && { type: "email", label: "Email", href: `mailto:${links.email}` },
  links.website && { type: "website", label: "Website", href: links.website },
  links.scholar && { type: "scholar", label: "Google Scholar", href: links.scholar },
  links.orcid && { type: "orcid", label: "ORCID", href: links.orcid },
  links.twitter && { type: "twitter", label: "X / Twitter", href: links.twitter },
  links.linkedin && { type: "linkedin", label: "LinkedIn", href: links.linkedin },
].filter(Boolean) as { type: LinkType; label: string; href: string }[];

// Brand glyphs (single-path simple-icons silhouettes). ORCID/LinkedIn/Scholar/X
// carry their brand color; email/website inherit the link text color.
const ICONS: Record<LinkType, { d: string; color?: string }> = {
  email: {
    d: "M1.5 8.67v8.58a3 3 0 0 0 3 3h15a3 3 0 0 0 3-3V8.67l-8.928 5.493a3 3 0 0 1-3.144 0L1.5 8.67ZM22.5 6.908V6.75a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3v.158l9.714 5.978a1.5 1.5 0 0 0 1.572 0L22.5 6.908Z",
  },
  website: {
    d: "M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 2c.9 0 2.3 1.5 3 4.5H9c.7-3 2.1-4.5 3-4.5ZM4.2 9h3a18 18 0 0 0 0 6h-3a8 8 0 0 1 0-6ZM5 17h2.6c.4 1.4 1 2.6 1.6 3.5A8 8 0 0 1 5 17Zm0-10a8 8 0 0 1 4.2-3.5C8.6 4.4 8 5.6 7.6 7H5Zm7 13.5c-.9 0-2.3-1.5-3-4.5h6c-.7 3-2.1 4.5-3 4.5Zm-3.3-6a16 16 0 0 1 0-6h6.6a16 16 0 0 1 0 6H8.7Zm6.7 5.5c.6-.9 1.2-2.1 1.6-3.5H19a8 8 0 0 1-3.6 3.5ZM16.7 15a18 18 0 0 0 0-6h3a8 8 0 0 1 0 6h-3Zm-.1-8c-.4-1.4-1-2.6-1.6-3.5A8 8 0 0 1 19 7h-2.4Z",
  },
  scholar: {
    d: "M5.242 13.769 0 9.5 12 0l12 9.5-5.242 4.269C17.548 11.249 14.978 9.5 12 9.5c-2.977 0-5.548 1.748-6.758 4.269zM12 10a7 7 0 1 0 0 14 7 7 0 0 0 0-14z",
    color: "#4285F4",
  },
  orcid: {
    d: "M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947 0 .525-.422.947-.947.947-.525 0-.946-.422-.946-.947 0-.516.421-.947.946-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.025-5.325 5.025h-3.919V7.416zm1.444 1.303v7.444h2.297c3.272 0 4.022-2.484 4.022-3.722 0-2.016-1.284-3.722-4.097-3.722h-2.222z",
    color: "#A6CE39",
  },
  twitter: {
    d: "M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z",
    color: "#0f172a",
  },
  linkedin: {
    d: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z",
    color: "#0A66C2",
  },
};
---

<BaseLayout title={name} description={`${role} — ${name}`}>
  <header class="bg-gradient-to-b from-primary-50 to-white">
    <div class="container-page py-10">
      <a
        href="/people"
        class="group inline-flex items-center gap-1 text-sm font-medium text-primary-700 transition-colors hover:text-accent-600"
      >
        <span class="transition-transform group-hover:-translate-x-0.5" aria-hidden="true">&larr;</span>
        All people
      </a>
      <div class="mt-6 grid gap-8 sm:grid-cols-[11rem_1fr] sm:items-center">
        <div class="mx-auto h-44 w-44 overflow-hidden rounded-full shadow-sm ring-1 ring-slate-200 sm:mx-0">
          {
            headshot ? (
              <Image
                src={headshot}
                alt={name}
                width={352}
                height={352}
                class="h-full w-full object-cover"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center bg-primary-100 text-4xl font-semibold text-primary-700">
                {initials}
              </div>
            )
          }
        </div>

        <div>
          <h1 class="font-serif text-3xl text-slate-900 sm:text-4xl">{name}</h1>
          <p class="mt-1 text-lg text-primary-700">{role}</p>
          {title && <p class="mt-1 max-w-2xl text-slate-600">{title}</p>}
          {
            linkItems.length > 0 && (
              <ul class="mt-4 flex flex-wrap items-center gap-3">
                {linkItems.map((l) => (
                  <li>
                    <a
                      href={l.href}
                      target={l.href.startsWith("mailto:") ? undefined : "_blank"}
                      rel="noopener noreferrer"
                      class="inline-flex text-primary-700 transition-opacity hover:opacity-70"
                      title={l.label}
                      aria-label={l.label}
                    >
                      <svg
                        viewBox="0 0 24 24"
                        class="h-5 w-5"
                        fill={ICONS[l.type].color ?? "currentColor"}
                        aria-hidden="true"
                      >
                        <path d={ICONS[l.type].d} />
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </div>
    </div>
  </header>

  <div class="container-page py-12">
    <div class="max-w-3xl">
      <slot />
    </div>
  </div>
</BaseLayout>
